{
  "$schema": "https://schemas.zeropress.dev/build-pages-config/v0.1/schema.json",
  "version": "0.1",
  "site": {
    "title": "ZeroPress Build Pages",
    "description": "Build Markdown-source ZeroPress sites for static hosting.",
    "url": "https://build-pages.zeropress.dev",
    "locale": "en-US",
